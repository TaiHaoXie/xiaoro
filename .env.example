# ================================
# 环境变量配置文件
# ================================
# 使用方式: 复制此文件为 .env，然后填入真实值
# 命令: cp .env.example .env

# ========== 应用配置 ==========
APP_NAME=电商智能导购Agent
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ========== 服务器配置 ==========
HOST=0.0.0.0
PORT=8000

# ========== 数据库配置 ==========
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=ecommerce_agent

# Milvus (向量数据库)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Redis (缓存)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== LLM API 配置 ==========
# 豆包 API (主用)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=ep-your-chat-endpoint
DOUBAO_EMBEDDING_MODEL=ep-your-embedding-endpoint
DOUBAO_VISION_MODEL=ep-your-vision-endpoint

# Embedding: auto 会在 endpoint 无效时直接使用本地稳定向量，避免演示日志反复降级
EMBEDDING_PROVIDER=auto
EMBEDDING_DIMENSION=1024

# Intent: 默认关闭外部LLM分类，用规则+场景分类保证演示稳定
INTENT_LLM_ENABLED=false
INTENT_LLM_CONFIDENCE_THRESHOLD=0.35

# Kimi API (备用)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_CHAT_MODEL=moonshot-v1-8k

# 硅基流动 SiliconFlow (OpenAI 兼容，默认主用 - DeepSeek)
DEFAULT_LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_CHAT_MODEL=deepseek-ai/DeepSeek-V3.2

# 智谱 API (可选)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4

# ========== V2 Agent 开关 ==========
# V2 生成式大模型润色：默认 true(关闭)，设为 false/0 开启真实 LLM 润色
V2_DISABLE_LLM=true
# V2.2 状态机开关
V2_STATE_MACHINE_ENABLED=true
# V2 追问 LLM 裁判（影子模式默认关）
V2_FOLLOWUP_LLM_JUDGE_ENABLED=false
V2_FOLLOWUP_LLM_JUDGE_SHADOW_ENABLED=false

# ========== 对象存储配置 ==========
# MinIO (S3兼容)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecommerce

# ========== 安全配置 ==========
SECRET_KEY=your_secret_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 上传配置 ==========
MAX_UPLOAD_SIZE=10485760  # 10MB (字节)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========== Celery 配置（可选）==========
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
